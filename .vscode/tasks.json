{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Iniciar Servidor (Porta 3002)",
      "type": "shell",
      "command": "npm run dev -- -p 3002",
      "problemMatcher": ["$mdCompile"],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Validar Projeto (Arquitetura, Tipos, Lint)",
      "type": "shell",
      "command": "npm run validate",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Abrir Prisma Studio",
      "type": "shell",
      "command": "npx prisma studio",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Prisma: Executar Migrações",
      "type": "shell",
      "command": "npx prisma migrate dev",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
