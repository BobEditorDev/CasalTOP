// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TipoPagamento {
  RODRIGO_PAGA
  GIOVANA_PAGA
  RODRIGO_PAGOU_DA_GIOVANA
  GIOVANA_PAGOU_DO_RODRIGO
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String   @unique // "Rodrigo" | "Giovana"
  salario   Decimal  @db.Decimal(10, 2) // usado só pra calcular % de rateio
  senhaHash String
  gastos    Gasto[]
}

model Gasto {
  id                  String        @id @default(cuid())
  data                DateTime
  categoria           String
  tipo                TipoPagamento
  valor               Decimal       @db.Decimal(10, 2)
  observacao          String?
  parcelado           Boolean       @default(false)
  totalParcelas       Int?
  parcelaAtual        Int?
  parcelamentoGrupoId String?
  fixo                Boolean       @default(false)
  fixoGrupoId         String?
  criadoEm            DateTime      @default(now())
  atualizadoEm        DateTime      @updatedAt
  usuarioId           String
  usuario             Usuario       @relation(fields: [usuarioId], references: [id])
}

model Configuracao {
  id                String  @id @default(cuid())
  percentualRodrigo   Decimal @db.Decimal(5, 2) // 62.5
  percentualGiovana   Decimal @db.Decimal(5, 2) // 37.5
}
